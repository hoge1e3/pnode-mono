{
    "compilerOptions": {
      // ソースマップを有効化
      "sourceMap": true,
      // TSはECMAScript 5に変換
      "target": "ES2022",
      "lib": ["es2022"],
      // TSのモジュールはES Modulesとして出力
      //"allowImportingTsExtensions": true,
      //"noEmit": true,
      "module": "esnext",
      "moduleResolution": "node",
      //"module": "NodeNext",
      //"moduleResolution": "NodeNext",
      // 厳密モードとして設定
      "strict": true,
      "outDir":"./js",
      "rootDir": "./src",
      "allowSyntheticDefaultImports":true,
      "declaration": true,

      "incremental": true,
      "tsBuildInfoFile": "./.tsbuildinfo",
    },
    "include": ["src", "types/index.d.ts"]
  }